# ─────────────────────────────────────────────────────────────────
# DocFlow AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection String → URI (switch to "asyncpg" driver)
# Example: postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/docflow

# ── Redis (Celery Broker) ─────────────────────────────────────────
# Railway Redis: paste the Internal Redis URL from your Railway Redis service
# Example: redis://default:[password]@redis.railway.internal:6379
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 ────────────────────────────────────────────────────────
# Create an IAM user with S3 read/write permissions on your bucket.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=docflow-ai-uploads

# ── Anthropic (Claude) ────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Clerk Authentication ──────────────────────────────────────────
# Clerk Dashboard → API Keys → Secret Key
CLERK_SECRET_KEY=sk_live_...
# Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...
# Clerk Dashboard → API Keys → Publishable Key (also needed by frontend)
CLERK_PUBLISHABLE_KEY=pk_live_...
# Clerk JWKS URL: https://api.clerk.com/v1/jwks or your custom domain
CLERK_JWKS_URL=https://api.clerk.com/v1/jwks

# ── App Settings ──────────────────────────────────────────────────
# Max file upload size in bytes (default: 20 MB)
MAX_UPLOAD_BYTES=20971520
# Conservative baseline for ROI calculation: hours saved per processed document
HOURS_SAVED_PER_DOC_BASELINE=2.0
# Path to Tesseract executable (only needed if pytesseract fallback is used)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract
TESSERACT_CMD=tesseract
# Minimum average characters per page before falling back to OCR
OCR_FALLBACK_THRESHOLD=100

# ── Frontend (set these in your Vercel project settings too) ──────
# The public URL of this FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000
